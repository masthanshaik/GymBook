# Application Settings
DEBUG=False
HOST=0.0.0.0
PORT=8000
APP_NAME=GymBook

# Database
DATABASE_URL=postgresql://masthanshaik@localhost:5432/gymbook_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-long!!!
ALGORITHM=HS256

# CORS Origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://www.gymtrack.io"]

# Razorpay Integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_api_token

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@gymtrack.io

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_phone_number

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=gymtrack-uploads
AWS_REGION=us-east-1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend URLs
FRONTEND_URL=https://www.gymtrack.io
VENDOR_DASHBOARD_URL=https://dashboard.gymtrack.io
MEMBER_PORTAL_URL=https://member.gymtrack.io
